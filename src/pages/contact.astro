---
import Base from "../layouts/Base.astro";

const success = Astro.url.searchParams.get("success") === "true";
---

<Base title="Contact Us" description="Get in touch with us">
	<div class="contact-container">
		<header class="page-header">
			<h1 class="page-title">Contact Us</h1>
			<p class="page-subtitle">Have a question or just want to say hi? Drop us a line.</p>
		</header>

		{success ? (
			<div class="success-message">
				<h2>Thank you for your message!</h2>
				<p>We've received your inquiry and will get back to you shortly.</p>
				<a href="/" class="btn-home">Return Home</a>
			</div>
		) : (
		<form id="contactForm" class="contact-form">
			<input type="hidden" name="formId" value="contact" />
			<div class="form-group">
				<label for="name">Name</label>
				<input type="text" id="name" name="name" required placeholder="Your name" />
			</div>

			<div class="form-group">
				<label for="email">Email</label>
				<input type="email" id="email" name="email" required placeholder="your.email@example.com" />
			</div>

			<div class="form-group">
				<label for="subject">Subject</label>
				<input type="text" id="subject" name="subject" required placeholder="What is this regarding?" />
			</div>

			<div class="form-group">
				<label for="message">Message</label>
				<textarea id="message" name="message" rows="5" required placeholder="Your message..."></textarea>
			</div>

			<button type="submit" class="submit-btn">Send Message</button>
		</form>
		)}
	</div>
</Base>

<script>
	const form = document.getElementById("contactForm");
	if (form) {
		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const formData = new FormData(form as HTMLFormElement);
			const entries = Object.fromEntries(formData.entries());
			
			const payload = {
				formId: entries.formId,
				data: {
					name: entries.name,
					email: entries.email,
					subject: entries.subject,
					message: entries.message
				}
			};
			
			try {
				const response = await fetch("/_emdash/api/plugins/emdash-forms/submit", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload)
				});
				if (response.ok) {
					window.location.href = "/contact?success=true";
				} else {
					alert("Failed to submit form. Please try again.");
				}
			} catch (err) {
				alert("Network error.");
			}
		});
	}
</script>

<style>
	.success-message {
		text-align: center;
		padding: var(--spacing-8);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
	}
	.success-message h2 {
		color: var(--color-accent);
		margin-bottom: var(--spacing-4);
	}
	.success-message p {
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-6);
	}
	.btn-home {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border-radius: var(--radius);
		text-decoration: none;
		font-weight: 500;
	}

	.contact-container {
		max-width: 600px;
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.page-header {
		text-align: center;
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-4);
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
		background: var(--color-surface);
		padding: var(--spacing-8);
		border-radius: var(--radius-lg);
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.form-group label {
		font-weight: 500;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.form-group input,
	.form-group textarea {
		padding: var(--spacing-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-background);
		color: var(--color-text);
		font-family: inherit;
		font-size: var(--font-size-base);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.1);
	}

	.submit-btn {
		margin-top: var(--spacing-2);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border: none;
		border-radius: var(--radius);
		font-size: var(--font-size-base);
		font-weight: 500;
		cursor: pointer;
		transition: background var(--transition-fast), transform var(--transition-fast);
	}

	.submit-btn:hover {
		background: var(--color-accent-hover);
	}

	.submit-btn:active {
		transform: translateY(1px);
	}
</style>
